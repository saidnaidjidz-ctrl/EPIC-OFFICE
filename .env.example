################################################################################
#  Epic Club Management System — Environment Variables
#  Copy this file to .env and fill in ALL values before running docker-compose
#
#  SECURITY RULES:
#    - Never commit .env to version control
#    - Generate secrets with: openssl rand -base64 32
#    - Rotate secrets after any suspected compromise
################################################################################

# ─── Application ──────────────────────────────────────────────────────────────

# Your public-facing application URL (used by nginx and CORS)
# No trailing slash
APP_URL=https://epicclub.yourdomain.com

# Node environment mode
# Options: development | production | test
NODE_ENV=production

# Backend API internal port (not exposed externally — nginx proxies it)
BACKEND_PORT=5000

# Frontend internal port
FRONTEND_PORT=3000

# ─── Frontend Build Args ──────────────────────────────────────────────────────

# Public API URL visible to the browser (must be reachable from the client)
# In production with nginx, this should use the public domain + /api path
NEXT_PUBLIC_API_URL=https://epicclub.yourdomain.com/api

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────

# PostgreSQL database name
DB_NAME=epicclub_db

# PostgreSQL login user
# Do NOT use the superuser 'postgres' in production
DB_USER=epicclub_app

# REQUIRED — Strong database password
# Generate: openssl rand -base64 24
DB_PASSWORD=CHANGE_ME_strong_db_password_here

# ─── Redis ────────────────────────────────────────────────────────────────────

# REQUIRED — Redis authentication password
# Redis is configured with --requirepass using this value
# Generate: openssl rand -base64 24
REDIS_PASSWORD=CHANGE_ME_strong_redis_password_here

# ─── Authentication & JWT ─────────────────────────────────────────────────────

# REQUIRED — Secret key for signing JWT access tokens (short-lived)
# Generate: openssl rand -base64 32
# Must be at least 16 characters; 32+ strongly recommended for production
JWT_SECRET=CHANGE_ME_replace_with_openssl_rand_base64_32_output

# REQUIRED — Secret key for signing JWT refresh tokens (long-lived)
# Use a DIFFERENT value from JWT_SECRET
# Generate: openssl rand -base64 32
JWT_REFRESH_SECRET=CHANGE_ME_replace_with_different_openssl_rand_base64_32

# ─── Google OAuth 2.0 ─────────────────────────────────────────────────────────

# Your Google Cloud Console OAuth 2.0 Client ID
# Create at: https://console.cloud.google.com/apis/credentials
# Add your APP_URL to the list of authorized JavaScript origins and redirect URIs
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ─── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins
# Must match the exact origins browsers use to call the API
# In production, only include your app URL (no trailing slash)
CORS_ALLOWED_ORIGINS=https://epicclub.yourdomain.com

# ─── SSL / TLS ────────────────────────────────────────────────────────────────
# SSL certificates are mounted into the nginx container from ./nginx/ssl/
# Required files:
#   ./nginx/ssl/fullchain.pem   — Full certificate chain (cert + intermediates)
#   ./nginx/ssl/privkey.pem     — Private key
#
# Using Let's Encrypt (Certbot):
#   certbot certonly --standalone -d epicclub.yourdomain.com
#   cp /etc/letsencrypt/live/epicclub.yourdomain.com/fullchain.pem ./nginx/ssl/
#   cp /etc/letsencrypt/live/epicclub.yourdomain.com/privkey.pem    ./nginx/ssl/
