# Server Config
PORT=3000
NODE_ENV=development

# Database Config (PostgreSQL connection string or components)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/epicclub_db
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=epicclub_db

# Redis Config (used for rate-limiting, session management, or blacklisting)
REDIS_URL=redis://localhost:6379

# JWT Configurations
# Generate secure keys using: openssl rand -base64 32
JWT_SECRET=super_secret_access_token_key_change_me_in_production
JWT_REFRESH_SECRET=super_secret_refresh_token_key_change_me_in_production

# CORS Configuration
# Comma-separated list of allowed origin URLs
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Google OAuth 2.0 Credentials
GOOGLE_CLIENT_ID=your_google_client_id_goes_here.apps.googleusercontent.com

# Frontend Application URL (used for magic link generation in emails)
FRONTEND_URL=http://localhost:3001

# SMTP Email Configuration (for sending verification / notification emails)
# Gmail example: use App Password from https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-email@gmail.com
